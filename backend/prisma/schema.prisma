generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  DONE
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum NotificationType {
  PROJECT_INVITATION
  TASK_ASSIGNED
  TASK_UPDATED
  TASK_COMMENT
  DEADLINE_WARNING
  STATUS_CHANGED
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum SchedulingSource {
  AUTO
  MANUAL
}

enum DependencyType {
  FINISH_TO_START
  START_TO_START
  FINISH_TO_FINISH
}

enum FlexibilityLevel {
  FIXED
  FLEXIBLE
  ADAPTIVE
}

enum SuggestionStatus {
  PENDING
  APPLIED
  REJECTED
}


model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  jobTitle      String?
  department    String?
  bio           String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ownedProjects Project[]             @relation("Owner")
  memberProjects Project[]            @relation("Member")
  assignedTasks Task[]                @relation("Assignee")
  createdTasks  Task[]                @relation("Creator")
  reviewedTasks Task[]                @relation("Reviewer")
  activities    ActivityLog[]
  comments      Comment[]
  notifications Notification[]
  plannerProfile UserPlannerProfile?
  calendarEvents CalendarEvent[]
  scheduledBlocks ScheduledTaskBlock[]
  assistantSuggestions AssistantSuggestion[]
}

model Otp {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)
  health      Int           @default(0)
  color       String        @default("#2563eb")
  icon        String        @default("layers")
  ownerId     String
  startDate   DateTime?
  dueDate     DateTime?
  archivedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  owner       User                @relation("Owner", fields: [ownerId], references: [id])
  members     User[]              @relation("Member")
  tasks       Task[]
  invitations ProjectInvitation[]
  milestones  ProjectMilestone[]
  labels      Label[]
  savedViews  SavedView[]
  recurringRules RecurringTaskRule[]
  riskAlerts     RiskAlert[]
}

model ProjectInvitation {
  id        String           @id @default(uuid())
  projectId String
  email     String
  status    InvitationStatus @default(PENDING)
  createdAt DateTime         @default(now())
  respondedAt DateTime?

  project   Project          @relation(fields: [projectId], references: [id])
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  deadline    DateTime?
  assigneeId  String?
  projectId   String
  createdById String
  reviewerId  String?
  blockedReason String?
  estimatedMinutes Int?
  actualMinutes Int       @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  position    Int         @default(0)
  
  // New Scheduling Fields
  importance  Int         @default(1) // 1-5
  urgencyScore Float       @default(0.0)
  flexibility FlexibilityLevel @default(FLEXIBLE)
  isAutoScheduled Boolean   @default(false)
  preferredTime DateTime?
  latestStartAt DateTime?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  assignee    User?       @relation("Assignee", fields: [assigneeId], references: [id])
  project     Project     @relation(fields: [projectId], references: [id])
  createdBy   User        @relation("Creator", fields: [createdById], references: [id])
  reviewer    User?       @relation("Reviewer", fields: [reviewerId], references: [id])
  comments    Comment[]
  labels      TaskLabel[]
  subtasks    Subtask[]
  timeEntries TimeEntry[]
  scheduledBlocks ScheduledTaskBlock[]
  dependencies    TaskDependency[] @relation("Successor")
  predecessors    TaskDependency[] @relation("Predecessor")
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String
  action     String   // CREATE_PROJECT, UPDATE_TASK, ASSIGN_TASK, etc.
  entityType String   // PROJECT, TASK, USER
  entityId   String
  projectId  String?
  taskId     String?
  details    Json?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
}

model Comment {
  id        String   @id @default(uuid())
  taskId     String
  authorId   String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  task       Task     @relation(fields: [taskId], references: [id])
  author     User     @relation(fields: [authorId], references: [id])
}

model Notification {
  id         String           @id @default(uuid())
  userId     String
  type       NotificationType
  title      String
  message    String
  targetUrl  String?
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  user       User             @relation(fields: [userId], references: [id])
}

model ProjectMilestone {
  id         String   @id @default(uuid())
  projectId  String
  title      String
  dueDate    DateTime?
  createdAt  DateTime @default(now())

  project    Project  @relation(fields: [projectId], references: [id])
}

model Label {
  id         String   @id @default(uuid())
  projectId   String
  name        String
  color       String   @default("#2563eb")
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id])
  tasks       TaskLabel[]
}

model TaskLabel {
  taskId      String
  labelId     String

  task        Task     @relation(fields: [taskId], references: [id])
  label       Label    @relation(fields: [labelId], references: [id])

  @@id([taskId, labelId])
}

model Subtask {
  id          String   @id @default(uuid())
  taskId       String
  title        String
  completed    Boolean  @default(false)
  createdAt    DateTime @default(now())

  task         Task     @relation(fields: [taskId], references: [id])
}

model SavedView {
  id          String   @id @default(uuid())
  projectId    String
  name         String
  filters      Json
  createdAt    DateTime @default(now())

  project      Project  @relation(fields: [projectId], references: [id])
}

model ProjectTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  color       String   @default("#2563eb")
  icon        String   @default("layers")
  createdAt   DateTime @default(now())

  tasks       TemplateTask[]
}

model TemplateTask {
  id          String   @id @default(uuid())
  templateId   String
  title        String
  description  String?
  priority     TaskPriority @default(MEDIUM)
  status       TaskStatus   @default(TODO)
  estimatedMinutes Int?
  order        Int      @default(0)

  template     ProjectTemplate @relation(fields: [templateId], references: [id])
}

model RecurringTaskRule {
  id          String   @id @default(uuid())
  projectId    String
  title        String
  description  String?
  priority     TaskPriority @default(MEDIUM)
  frequency    RecurringFrequency
  interval     Int      @default(1)
  nextRunAt    DateTime
  assigneeId   String?
  reviewerId   String?
  estimatedMinutes Int?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  project      Project  @relation(fields: [projectId], references: [id])
}

model TimeEntry {
  id          String   @id @default(uuid())
  taskId       String
  userId       String
  minutes      Int
  note         String?
  createdAt    DateTime @default(now())

  task         Task     @relation(fields: [taskId], references: [id])
}

model CalendarEvent {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  location    String?
  isBusy      Boolean  @default(true)
  externalId  String?  // For future Google/Outlook sync
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

model ScheduledTaskBlock {
  id          String   @id @default(uuid())
  taskId      String
  userId      String
  startAt     DateTime
  endAt       DateTime
  source      SchedulingSource @default(AUTO)
  confidence  Float            @default(1.0)
  isLocked    Boolean          @default(false)
  createdAt   DateTime         @default(now())

  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])
}

model UserPlannerProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  workHours   Json?    // WorkHourProfile structure
  focusWindows Json?   // FocusWindow structure
  maxMeetingsPerDay Int?
  chunkingPreference Int @default(60) // Preferred task duration in minutes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

model TaskDependency {
  id          String         @id @default(uuid())
  predecessorId String
  successorId   String
  type          DependencyType @default(FINISH_TO_START)

  predecessor   Task           @relation("Predecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  successor     Task           @relation("Successor", fields: [successorId], references: [id], onDelete: Cascade)
}

model AssistantSuggestion {
  id          String           @id @default(uuid())
  userId      String
  title       String
  description String
  actionType  String           // REBALANCE, PLAN_DAY, RESCHEDULE_RISK
  payload     Json?            // Data needed to apply suggestion
  status      SuggestionStatus @default(PENDING)
  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id])
}

model RiskAlert {
  id          String   @id @default(uuid())
  projectId   String
  level       String   // INFO, WARNING, CRITICAL
  message     String
  isResolved  Boolean  @default(false)
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id])
}
